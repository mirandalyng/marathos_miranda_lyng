{
  "datasets": [
    {
      "name": "af00141f",
      "displayName": "Top Marathon Events by Distance Dataset",
      "queryLines": [
        "SELECT \n",
        "    event_name, \n",
        "    event_distance_km\n",
        "FROM marathos.gold.mart_marathon_distance\n",
        "ORDER BY event_distance_km DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "a48a7344",
      "displayName": "Top Marathon Events by Distance",
      "queryLines": [
        "SELECT DISTINCT\n",
        "    event_name, \n",
        "    event_distance_h\n",
        "FROM marathos.gold.mart_marathon_length\n",
        "ORDER BY event_distance_h desc\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "1e2eff3a",
      "displayName": "Top Marathon Events Ranked by Distance or Duration",
      "queryLines": [
        "SELECT event_name, metric_value, metric_type\n",
        "FROM (\n",
        "    SELECT event_name, metric_value, metric_type,\n",
        "        ROW_NUMBER() OVER (ORDER BY metric_value DESC) AS rn\n",
        "    FROM (\n",
        "        SELECT event_name, MAX(event_distance_km) AS metric_value, 'distance' AS metric_type\n",
        "        FROM marathos.gold.mart_marathon_distance\n",
        "        WHERE event_distance_km IS NOT NULL\n",
        "        GROUP BY event_name\n",
        "    )\n",
        "\n",
        "    UNION ALL\n",
        "\n",
        "    SELECT event_name, metric_value, metric_type,\n",
        "        ROW_NUMBER() OVER (ORDER BY metric_value DESC) AS rn\n",
        "    FROM (\n",
        "        SELECT event_name, MAX(event_distance_h) AS metric_value, 'length' AS metric_type\n",
        "        FROM marathos.gold.mart_marathon_length\n",
        "        WHERE event_distance_h IS NOT NULL\n",
        "        GROUP BY event_name\n",
        "    )\n",
        ")\n",
        "WHERE rn <= 10\n",
        "AND metric_type = :metric_type\n",
        "ORDER BY metric_value DESC"
      ],
      "parameters": [
        {
          "displayName": "metric_type",
          "keyword": "metric_type",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "distance"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "8ebf0788",
      "displayName": "Top Marathon Events by Finishers Across Key Nations",
      "queryLines": [
        "SELECT \n",
        "DISTINCT\n",
        "    event_country,\n",
        "    event_country_name,\n",
        "    event_distance_km,\n",
        "    event_distance_h,\n",
        "    event_number_of_finisher\n",
        "FROM marathos.gold.dim_event\n",
        "WHERE event_country IN ('BRA', 'USA', 'CHN', 'AUS', 'NGA', 'RUS', 'CAN', 'DEU', 'EGY', 'ARG')\n",
        "ORDER BY event_number_of_finisher DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "f90a1874",
      "displayName": "Top Brazilian Marathon Finishers and Event Details Dataset",
      "queryLines": [
        "select \n",
        "    event_country, \n",
        "    event_country_name, \n",
        "    event_distance_h, \n",
        "    event_number_of_finisher\n",
        "from marathos.gold.dim_event \n",
        "where event_country = 'BRA'\n",
        "order by event_number_of_finisher desc\n",
        "limit 10"
      ]
    },
    {
      "name": "6d7c7fb5",
      "displayName": "longest_km_race",
      "queryLines": [
        "\n",
        "SELECT \n",
        "    event_name,\n",
        "    MAX(event_distance_km) AS longest_race_km\n",
        "FROM marathos.gold.mart_marathon_distance\n",
        "GROUP BY event_name\n",
        "ORDER BY longest_race_km DESC\n",
        "LIMIT 1"
      ]
    },
    {
      "name": "18ef51e6",
      "displayName": "longest_h_race",
      "queryLines": [
        "SELECT \n",
        "    event_name,\n",
        "    MAX(event_distance_h) AS longest_race_h\n",
        "FROM marathos.gold.mart_marathon_length\n",
        "WHERE event_distance_h IS NOT NULL\n",
        "GROUP BY event_name\n",
        "ORDER BY longest_race_h DESC\n",
        "LIMIT 1"
      ]
    },
    {
      "name": "fea1c6d5",
      "displayName": "shortest_km_race",
      "queryLines": [
        "\n",
        "SELECT \n",
        "    event_name,\n",
        "    MIN(event_distance_km) AS shortest_race\n",
        "FROM marathos.gold.mart_marathon_distance\n",
        "GROUP BY event_name\n",
        "ORDER BY shortest_race ASC\n",
        "LIMIT 1"
      ]
    },
    {
      "name": "05671e07",
      "displayName": "shortest_h_race",
      "queryLines": [
        "SELECT \n",
        "    event_name,\n",
        "    MIN(event_distance_h) AS shortest_race\n",
        "FROM marathos.gold.mart_marathon_length\n",
        "WHERE event_distance_h IS NOT NULL\n",
        "GROUP BY event_name\n",
        "ORDER BY shortest_race asc\n",
        "LIMIT 1"
      ]
    },
    {
      "name": "90690494",
      "displayName": "fastest_male",
      "queryLines": [
        "SELECT\n",
        "    a.athlete_gender,\n",
        "    fr.athlete_average_speed\n",
        "FROM marathos.gold.fct_results fr\n",
        "LEFT JOIN marathos.gold.dim_athlete a ON fr.athlete_id = a.athlete_id\n",
        "LEFT JOIN marathos.gold.dim_event e ON fr.event_id = e.event_id\n",
        "WHERE fr.athlete_average_speed IS NOT NULL\n",
        "AND a.athlete_gender IN ('M')\n",
        "AND e.event_unit IN ('km', 'mi')\n",
        "ORDER BY fr.athlete_average_speed DESC\n",
        "LIMIT 10\n"
      ]
    },
    {
      "name": "7dec98c3",
      "displayName": "fastest_female",
      "queryLines": [
        "SELECT\n",
        "    a.athlete_gender,\n",
        "    fr.athlete_average_speed\n",
        "FROM marathos.gold.fct_results fr\n",
        "LEFT JOIN marathos.gold.dim_athlete a ON fr.athlete_id = a.athlete_id\n",
        "LEFT JOIN marathos.gold.dim_event e ON fr.event_id = e.event_id\n",
        "WHERE fr.athlete_average_speed IS NOT NULL\n",
        "AND a.athlete_gender IN ('F')\n",
        "AND e.event_unit IN ('km', 'mi')\n",
        "ORDER BY fr.athlete_average_speed DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "d5d259c9",
      "displayName": "fastest_male_h",
      "queryLines": [
        "SELECT\n",
        "    a.athlete_gender,\n",
        "    fr.athlete_average_speed\n",
        "FROM marathos.gold.fct_results fr\n",
        "LEFT JOIN marathos.gold.dim_athlete a ON fr.athlete_id = a.athlete_id\n",
        "LEFT JOIN marathos.gold.dim_event e ON fr.event_id = e.event_id\n",
        "WHERE fr.athlete_average_speed IS NOT NULL\n",
        "AND a.athlete_gender IN ('M')\n",
        "AND e.event_unit IN ('h')\n",
        "ORDER BY fr.athlete_average_speed DESC\n",
        "LIMIT 10\n"
      ]
    },
    {
      "name": "7995add8",
      "displayName": "fastest_female_h",
      "queryLines": [
        "SELECT\n",
        "    a.athlete_gender,\n",
        "    fr.athlete_average_speed\n",
        "FROM marathos.gold.fct_results fr\n",
        "LEFT JOIN marathos.gold.dim_athlete a ON fr.athlete_id = a.athlete_id\n",
        "LEFT JOIN marathos.gold.dim_event e ON fr.event_id = e.event_id\n",
        "WHERE fr.athlete_average_speed IS NOT NULL\n",
        "AND a.athlete_gender IN ('F')\n",
        "AND e.event_unit IN ('h')\n",
        "ORDER BY fr.athlete_average_speed DESC\n",
        "LIMIT 10\n"
      ]
    },
    {
      "name": "99c0f696",
      "displayName": "Top Ten Countries by Count of Unique Marathon Events",
      "queryLines": [
        "SELECT \n",
        "    e.event_country,\n",
        "    COUNT(DISTINCT fr.race_id) AS number_of_races\n",
        "FROM marathos.gold.fct_results fr\n",
        "LEFT JOIN marathos.gold.dim_event e ON fr.event_id = e.event_id\n",
        "WHERE e.event_country IS NOT NULL\n",
        "GROUP BY e.event_country\n",
        "ORDER BY number_of_races DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "5064d7dc",
      "displayName": "race per yar",
      "queryLines": [
        "SELECT \n",
        "    year_of_event,\n",
        "    COUNT(DISTINCT race_id) AS number_of_races\n",
        "FROM marathos.gold.dim_race\n",
        "WHERE year_of_event IS NOT NULL\n",
        "GROUP BY year_of_event\n",
        "ORDER BY year_of_event DESC \n",
        "LIMIT 10 \n"
      ]
    }
  ],
